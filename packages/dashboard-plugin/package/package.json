{
  "name": "@openclaw-dashboard/dashboard-plugin",
  "version": "1.0.0",
  "description": "Openclaw plugin for Dashboard web chat interface",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "index.ts",
    "tsconfig.json",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "dashboard",
    "chat"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  }
}