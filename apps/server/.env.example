# Server Configuration
PORT=3001
HOST=0.0.0.0
DB_PATH=./data/dashboard.db

# Plugin Authentication Token
PLUGIN_TOKEN=your-secure-token

# Openclaw Gateway Direct Connection (Optional)
# If configured, Dashboard will connect directly to Gateway
# If not configured, falls back to plugin mode
OPENCLAW_GATEWAY_URL=wss://your-gateway.example.com/ws
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# Optional Gateway Settings
# OPENCLAW_GATEWAY_RECONNECT_INTERVAL=5000
# OPENCLAW_GATEWAY_CONNECTION_TIMEOUT=30000
